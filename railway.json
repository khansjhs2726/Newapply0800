{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && PORT=3000 BASE_PATH=/ pnpm --filter @workspace/loan-app run build"
  },
  "deploy": {
    "startCommand": "npx serve artifacts/loan-app/dist/public -s -l $PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
